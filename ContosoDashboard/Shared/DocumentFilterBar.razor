@code {
    [Parameter] public DocumentFilterState Value { get; set; } = new();
    [Parameter] public EventCallback<DocumentFilterState> ValueChanged { get; set; }
    [Parameter] public IEnumerable<Project> Projects { get; set; } = Array.Empty<Project>();
    [Parameter] public EventCallback OnApply { get; set; }
    [Parameter] public EventCallback OnClear { get; set; }

    private DocumentFilterState workingState = new();

    protected override void OnParametersSet()
    {
        workingState = new DocumentFilterState
        {
            Category = Value.Category,
            ProjectId = Value.ProjectId,
            FromDate = Value.FromDate,
            ToDate = Value.ToDate,
            SortBy = Value.SortBy,
            Direction = Value.Direction
        };
    }

    private async Task ApplyAsync()
    {
        await ValueChanged.InvokeAsync(workingState);
        await OnApply.InvokeAsync();
    }

    private async Task ClearAsync()
    {
        workingState = new DocumentFilterState();
        await ValueChanged.InvokeAsync(workingState);
        await OnClear.InvokeAsync();
    }
}

<div class="mb-3">
    <label class="form-label">Category</label>
    <select class="form-select" @bind="workingState.Category">
        <option value="">All categories</option>
        @foreach (var category in DocumentCategories.All)
        {
            <option value="@category">@category</option>
        }
    </select>
</div>

<div class="mb-3">
    <label class="form-label">Project</label>
    <select class="form-select" @bind="workingState.ProjectId">
        <option value="">All projects</option>
        @foreach (var project in Projects)
        {
            <option value="@project.ProjectId">@project.Name</option>
        }
    </select>
</div>

<div class="row g-2 mb-3">
    <div class="col-md-6">
        <label class="form-label">From</label>
        <InputDate class="form-control" @bind-Value="workingState.FromDate" />
    </div>
    <div class="col-md-6">
        <label class="form-label">To</label>
        <InputDate class="form-control" @bind-Value="workingState.ToDate" />
    </div>
</div>

<div class="row g-2 mb-3">
    <div class="col-md-6">
        <label class="form-label">Sort</label>
        <select class="form-select" @bind="workingState.SortBy">
            <option value="uploadedAt">Upload date</option>
            <option value="title">Title</option>
            <option value="category">Category</option>
            <option value="size">File size</option>
        </select>
    </div>
    <div class="col-md-6">
        <label class="form-label">Direction</label>
        <select class="form-select" @bind="workingState.Direction">
            <option value="desc">Descending</option>
            <option value="asc">Ascending</option>
        </select>
    </div>
</div>

<div class="d-flex gap-2">
    <button type="button" class="btn btn-primary" @onclick="ApplyAsync">Apply</button>
    <button type="button" class="btn btn-outline-secondary" @onclick="ClearAsync">Clear</button>
</div>
