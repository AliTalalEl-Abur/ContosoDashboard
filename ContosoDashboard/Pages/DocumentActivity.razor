@page "/documents/activity"
@using ModelDocumentActivity = ContosoDashboard.Models.DocumentActivity
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "Administrator")]
@inject IDocumentActivityService DocumentActivityService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Document Activity - ContosoDashboard</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1>Document Activity</h1>
            <p class="text-muted mb-0">Administrator audit trail for document events.</p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Action</label>
                    <select class="form-select" @bind="actionTypeFilter">
                        <option value="">All</option>
                        @foreach (var action in actionTypes)
                        {
                            <option value="@action">@action</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Actor User ID</label>
                    <input class="form-control" type="number" @bind="actorUserIdFilter" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Document ID</label>
                    <input class="form-control" type="number" @bind="documentIdFilter" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">From</label>
                    <InputDate class="form-control" @bind-Value="fromFilter" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">To</label>
                    <InputDate class="form-control" @bind-Value="toFilter" />
                </div>
                <div class="col-md-1 d-grid">
                    <label class="form-label">&nbsp;</label>
                    <button class="btn btn-primary" @onclick="LoadActivities">Apply</button>
                </div>
            </div>
        </div>
    </div>

    @if (activities == null)
    {
        <p><em>Loading...</em></p>
    }
    else if (!activities.Any())
    {
        <div class="alert alert-info">No activity has been recorded yet.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Action</th>
                        <th>Document</th>
                        <th>Actor</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var activity in activities)
                    {
                        <tr>
                            <td>@activity.OccurredAtUtc.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                            <td><span class="badge bg-secondary">@activity.ActionType</span></td>
                            <td>@activity.Document.Title</td>
                            <td>@activity.ActorUser.DisplayName</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<ModelDocumentActivity>? activities;
    private int currentUserId;
    private readonly string[] actionTypes =
    [
        DocumentActivityTypes.Upload,
        DocumentActivityTypes.Download,
        DocumentActivityTypes.Share,
        DocumentActivityTypes.UpdateMetadata,
        DocumentActivityTypes.ReplaceFile,
        DocumentActivityTypes.Delete
    ];
    private string? actionTypeFilter;
    private int? actorUserIdFilter;
    private int? documentIdFilter;
    private DateTime? fromFilter;
    private DateTime? toFilter;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (!int.TryParse(authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out currentUserId))
        {
            return;
        }

        await LoadActivities();
    }

    private async Task LoadActivities()
    {
        activities = await DocumentActivityService.GetActivityAsync(
            currentUserId,
            actionTypeFilter,
            actorUserIdFilter,
            documentIdFilter,
            fromFilter,
            toFilter);
    }
}
